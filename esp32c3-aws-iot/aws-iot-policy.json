{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": "iot:Connect",
      "Resource": "arn:aws:iot:us-west-2:ACCOUNT_ID:client/basicPubSub"
    },
    {
      "Effect": "Allow",
      "Action": "iot:Subscribe",
      "Resource": [
        "arn:aws:iot:us-west-2:ACCOUNT_ID:topicfilter/esp32c3/awsiot1/led/set",
        "arn:aws:iot:us-west-2:ACCOUNT_ID:topicfilter/sdk/test/python"
      ]
    },
    {
      "Effect": "Allow",
      "Action": "iot:Receive",
      "Resource": [
        "arn:aws:iot:us-west-2:ACCOUNT_ID:topic/esp32c3/awsiot1/led/set",
        "arn:aws:iot:us-west-2:ACCOUNT_ID:topic/sdk/test/python"
      ]
    },
    {
      "Effect": "Allow",
      "Action": "iot:Publish",
      "Resource": [
        "arn:aws:iot:us-west-2:ACCOUNT_ID:topic/esp32c3/awsiot1/led/state",
        "arn:aws:iot:us-west-2:ACCOUNT_ID:topic/sdk/test/python"
      ]
    }
  ]
}
